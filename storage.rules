rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Businesses folder
    match /businesses/{businessId}/{allPaths=**} {
      // Anyone can read business photos (Discovery screen)
      allow read: if true;
      // Only the business owner can upload/update/delete their photos
      allow write: if request.auth != null && request.auth.uid == businessId;
    }

    // Users folder
    match /users/{userId}/{allPaths=**} {
      // Anyone can read profile photos (Reviews/Social)
      allow read: if true;
      // Only the user themselves can upload/update/delete their profile photo
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
